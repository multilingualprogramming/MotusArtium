# ============================================================================
# Requêtes géographiques
# ============================================================================

asynchrone déf obtenir_diffusion_geographique(mouvement_id: chaine) -> liste:
    """Récupère la diffusion géographique d'un mouvement via GraphQL"""
    donnees_mouvement = attendre executer_requete_graphql(
        "movement_diffusion.graphql",
        {
            "id": mouvement_id,
            "languageCode": LANGUE_PAR_DEFAUT
        }
    )

    item = donnees_mouvement.obtenir("item", {})
    pays = _extraire_items(item.obtenir("country", []))
    ids_pays = [entree.obtenir("id", "") pour entree dans pays si entree.obtenir("id", "")]

    si non ids_pays:
        retourner []

    donnees_pays = attendre executer_requete_graphql(
        "countries_coordinates.graphql",
        {
            "ids": ids_pays,
            "languageCode": LANGUE_PAR_DEFAUT
        }
    )

    pays_par_id = {}
    pour pays_item dans donnees_pays.obtenir("itemsById", []):
        pays_id = pays_item.obtenir("id", "")
        si pays_id:
            pays_par_id[pays_id] = pays_item

    resultats = []

    pour pays_entree dans pays:
        pays_id = pays_entree.obtenir("id", "")
        pays_item = pays_par_id.obtenir(pays_id, {})
        coordonnees = _extraire_coordonnees(pays_item.obtenir("coordinate", []))

        resultats.ajouter({
            "movement": _champ_entite(item.obtenir("id", "")),
            "movementLabel": _champ_valeur(item.obtenir("movementLabel", "")),
            "country": _champ_entite(pays_id),
            "countryLabel": _champ_valeur(pays_entree.obtenir("label", "")),
            "coordinate": _champ_valeur(coordonnees)
        })

    retourner resultats


asynchrone déf obtenir_oeuvres_musee(musee_id: chaine, limite: nombre = 50) -> liste:
    """Récupère les œuvres d'un musée via GraphQL"""
    donnees = attendre executer_requete_graphql(
        "artworks_by_museum.graphql",
        {
            "museumId": musee_id,
            "languageCode": LANGUE_PAR_DEFAUT
        }
    )

    edges = donnees.obtenir("searchItems", {}).obtenir("edges", [])
    resultats = []

    pour edge dans edges:
        noeud = edge.obtenir("node", {})
        si noeud and len(resultats) < limite:
            resultats.ajouter(_normaliser_oeuvre_resume(noeud))

    retourner resultats


# ============================================================================
# Requêtes de chronologie
# ============================================================================

asynchrone déf obtenir_chronologie_mouvements(debut: nombre, fin: nombre) -> liste:
    """Récupère une chronologie des mouvements artistiques via GraphQL"""
    mouvements = attendre _recuperer_mouvements_catalogue()
    resultats = []

    pour mouvement dans mouvements:
        entree = _normaliser_chronologie(mouvement)
        debut_mouvement = _annee_depuis_temps(entree.obtenir("startTime", {}).obtenir("value", ""))
        fin_mouvement = _annee_depuis_temps(entree.obtenir("endTime", {}).obtenir("value", ""))

        si debut_mouvement et fin_mouvement and debut_mouvement >= debut and fin_mouvement <= fin:
            resultats.ajouter(entree)

    retourner resultats


# ============================================================================
# Contrats GraphQL de plus haut niveau pour le graphe applicatif
# ============================================================================

asynchrone déf obtenir_etiquette_entite(entite_id: chaine, langue: chaine = LANGUE_PAR_DEFAUT) -> dictionnaire:
    """Recuperer une etiquette simple pour une entite."""
    donnees = attendre executer_requete_graphql(
        "entity_label.graphql",
        {
            "id": entite_id,
            "languageCode": langue
        }
    )

    item = donnees.obtenir("item", {})
    retourner {
        "id": item.obtenir("id", ""),
        "label": item.obtenir("label", "")
    }


asynchrone déf obtenir_etiquettes_entite(entite_id: chaine, langues: liste = ["fr", "en"]) -> dictionnaire:
    """Recuperer plusieurs etiquettes d'une meme entite."""
    etiquettes = {}

    pour langue dans langues ou []:
        si non langue:
            passe

        etiquette = attendre obtenir_etiquette_entite(entite_id, langue)
        observer etiquettes[langue] = etiquette.obtenir("label", "")

    retourner etiquettes


asynchrone déf obtenir_graphe_mouvement(mouvement_id: chaine, limite: nombre = 50) -> dictionnaire:
    """Retourner le contrat de graphe canonique pour un mouvement."""
    mouvement = attendre obtenir_mouvement_details(mouvement_id)
    artistes = attendre obtenir_artistes_mouvement(mouvement_id, limite)

    retourner {
        "mouvement": mouvement,
        "artistes": artistes
    }


asynchrone déf obtenir_graphe_artiste(artiste_id: chaine, limite: nombre = 50) -> dictionnaire:
    """Retourner le contrat de graphe canonique pour un artiste."""
    artiste = attendre obtenir_artiste_details(artiste_id)
    oeuvres = attendre obtenir_oeuvres_artiste(artiste_id, limite)
    influences = attendre obtenir_influences_artiste(artiste_id)

    retourner {
        "artiste": artiste,
        "oeuvres": oeuvres,
        "influences": influences
    }


asynchrone déf obtenir_graphe_oeuvre(oeuvre_id: chaine) -> dictionnaire:
    """Retourner le contrat de graphe canonique pour une oeuvre."""
    donnees = attendre executer_requete_graphql(
        "artwork_details.graphql",
        {
            "id": oeuvre_id,
            "languageCode": LANGUE_PAR_DEFAUT
        }
    )

    item = donnees.obtenir("item", {})
    oeuvre = {}

    si item:
        oeuvre = _normaliser_oeuvre_detail(item)

    retourner {
        "oeuvre": oeuvre,
        "musee": _extraire_item(item.obtenir("museum", [])),
        "musees": _extraire_items(item.obtenir("museum", [])),
        "sujets": _extraire_items(item.obtenir("depicts", [])),
        "materiaux": _extraire_items(item.obtenir("material", []))
    }
