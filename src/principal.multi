    retour attendre ui.etat.charger_musee_oeuvres_page_suivante()


# ============================================================================
# Récit Mode — re-exports depuis ui.composants.recit
# ============================================================================

déf rendre_recit():
    """Rendre le récit narratif de l'entité sélectionnée"""
    retour ui.composants.recit.rendre_recit()


asynchrone déf basculer_mode_recit():
    """Basculer le mode récit dans la visualisation"""
    attendre ui.etat.basculer_visualisation("recit")
    retour ui.etat.obtenir_instantane_etat()


# ============================================================================
# Comparaison — re-exports depuis ui.etat et ui.composants.panneau_comparaison
# ============================================================================

déf rendre_panneau_comparaison():
    """Rendre le panneau de comparaison entre entités"""
    retour ui.composants.panneau_comparaison.rendre_panneau_comparaison()


asynchrone déf basculer_comparaison(entite_id: chaine, type_entite: chaine, etiquette: chaine):
    """Ajouter ou retirer une entité du panneau de comparaison, puis charger ses données"""
    ui.etat.basculer_comparaison(entite_id, type_entite, etiquette)
    attendre ui.etat.charger_donnees_comparaison(entite_id, type_entite)


déf effacer_comparaison():
    """Vider le panneau de comparaison"""
    ui.etat.effacer_comparaison()


# ============================================================================
# Trajectoire d'Influence — re-exports depuis ui.etat et ui.composants.trajectoire
# ============================================================================

déf rendre_trajectoire():
    """Rendre le panneau de trajectoire d'influence entre deux artistes"""
    retour ui.composants.trajectoire.rendre_trajectoire()


asynchrone déf basculer_artiste_trajectoire(artiste_id: chaine, etiquette: chaine):
    """Définir le départ ou l'arrivée de la trajectoire, lancer la recherche si les deux sont définis"""
    retour attendre ui.etat.basculer_artiste_trajectoire(artiste_id, etiquette)


asynchrone déf trouver_trajectoire_influence(depart_id: chaine, arrivee_id: chaine):
    """Trouver le chemin d'influence entre deux artistes"""
    retour attendre ui.etat.trouver_trajectoire_influence(depart_id, arrivee_id)


déf effacer_trajectoire():
    """Vider la trajectoire d'influence"""
    ui.etat.effacer_trajectoire()


# ============================================================================
# Grille de themes — re-export depuis ui.composants.grille_themes
