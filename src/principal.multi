importer ui.interactions.navigation
importer ui.etat
importer ui.i18n
importer donnees.requetes
importer donnees.normalisation
importer ui.visualisations.polyglot_studio_vue
importer ui.visualisations.chronologie_vue
importer semantique.intersections

# ui.etat is intentionally owned by Multilingual. The browser shell may keep a
# temporary compatibility fallback, but new application state belongs here.

asynchrone déf charger_mouvement(mouvement_id):
    """Charger un mouvement et retour l'entité sélectionnée"""
    attendre ui.etat.charger_mouvement(mouvement_id)
    ui.etat.obtenir_entite_selectionnee()


asynchrone déf charger_musee(musee_id):
    """Charger un musée et retour l'entité sélectionnée"""
    attendre ui.etat.charger_musee(musee_id)
    ui.etat.obtenir_entite_selectionnee()


asynchrone déf charger_sujet(sujet_id):
    """Charger les oeuvres d'un sujet thematique"""
    attendre ui.etat.charger_sujet(sujet_id)
    ui.etat.obtenir_entite_selectionnee()


asynchrone déf charger_artiste(artiste_id):
    """Charger un artiste et retour l'entité sélectionnée"""
    attendre ui.etat.charger_artiste(artiste_id)
    ui.etat.obtenir_entite_selectionnee()


asynchrone déf charger_oeuvre(oeuvre_id):
    """Charger une œuvre et retour l'entité sélectionnée"""
    attendre ui.etat.charger_oeuvre(oeuvre_id)
    ui.etat.obtenir_entite_selectionnee()


asynchrone déf charger_chronologie(debut, fin):
    """Charger une chronologie et retour un instantané d'état"""
    attendre ui.etat.charger_chronologie(debut, fin)
    ui.etat.obtenir_instantane_etat()


asynchrone déf basculer_visualisation(mode):
    """Basculer le mode de visualisation"""
    attendre ui.etat.basculer_visualisation(mode)
    ui.etat.obtenir_instantane_etat()


asynchrone déf basculer_langue(langue):
    """Basculer entre les langues"""
    attendre ui.etat.basculer_langue(langue)


déf basculer_affichage_surfaces():
    """Basculer l'affichage des surfaces polyglot (cote-a-cote vs onglets)"""
    ui.etat.basculer_affichage_surfaces()


asynchrone déf principal():
    """Point d'entrée principal de l'application"""
    attendre initialiser_application()
    ui.etat.obtenir_instantane_etat()


asynchrone déf initialiser_application():
    """Initialiser l'application avec un mouvement de départ"""
    attendre ui.etat.charger_mouvement("Q40415")


# ============================================================================
# Recherche et navigation
# ============================================================================

asynchrone déf rechercher_entites(requete: chaine) -> liste:
    """Rechercher des entités (cache + Wikidata) et retourner les résultats normalisés pour le shell JS"""
    si non requete ou len(requete) < 2:
        retour []

    carte_types = {"mouvement": "movement", "artiste": "artist", "oeuvre": "artwork"}
    resultats_cache = ui.interactions.recherche._rechercher_cache(requete)
    resultats_wikidata = attendre donnees.requetes.rechercher_entites_wikidata(requete)

    entites_vues = {}
    resultats = []
    pour r dans resultats_cache + resultats_wikidata:
        cle = r.obtenir("id", "")
        si cle et cle non dans entites_vues:
            entites_vues[cle] = vrai
            resultats.ajouter({
                "id": cle,
                "label": r.obtenir("label", cle),
                "description": r.obtenir("description", ""),
                "entityType": carte_types.obtenir(r.obtenir("type", ""), "")
            })
    retour resultats


asynchrone déf lancer_recherche(requete):
    """Lancer une recherche textuelle"""
    attendre ui.interactions.recherche.lancer_recherche(requete)


asynchrone déf ouvrir_barre_recherche():
    """Ouvrir la barre de recherche"""
    attendre ui.interactions.recherche.ouvrir_barre_recherche()


asynchrone déf fermer_barre_recherche():
    """Fermer la barre de recherche"""
    attendre ui.interactions.recherche.fermer_barre_recherche()


asynchrone déf resoudre_type_entite(entite_id, type_par_defaut):
    """Résoudre le type d'une entité via les claims Wikidata"""
    retour attendre ui.interactions.recherche.resoudre_type_entite(entite_id, type_par_defaut)


asynchrone déf charger_selection(entite_id, type_en, etiquette):
    """Charger une sélection de recherche et naviguer"""
    attendre ui.interactions.navigation.charger_selection(entite_id, type_en, etiquette)


