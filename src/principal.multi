asynchrone déf fermer_panneau_detail():
    """Fermer le panneau de détails"""
    attendre ui.composants.panneau_detail.fermer_panneau_detail()


déf rendre_panneau_detail():
    """Rendre le panneau de détails depuis le composant Multilingual"""
    retour ui.composants.panneau_detail.rendre_panneau_detail()


déf rendre_barre_recherche():
    """Rendre la barre de recherche depuis le composant Multilingual"""
