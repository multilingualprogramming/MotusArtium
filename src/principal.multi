# ============================================================================
# Pagination curseur — re-exports depuis ui.etat
# ============================================================================

asynchrone déf charger_mouvement_artistes_page_suivante():
    """Charger la page suivante d'artistes pour le mouvement courant"""
    retour attendre ui.etat.charger_mouvement_artistes_page_suivante()


asynchrone déf charger_artiste_oeuvres_page_suivante():
    """Charger la page suivante d'œuvres pour l'artiste courant"""
    retour attendre ui.etat.charger_artiste_oeuvres_page_suivante()


asynchrone déf charger_musee_oeuvres_page_suivante():
