    retour ui.composants.grille_themes.rendre_grille_themes()


# ============================================================================
# I18n — re-exports depuis ui.i18n
# ============================================================================

asynchrone déf charger_textes_interface():
    """Charger les textes d'interface depuis les fichiers JSON de locales."""
    retour attendre ui.i18n.charger_textes_interface()


déf obtenir_texte_interface(cle: chaine, langue: chaine = "fr") -> chaine:
    """Retourner un texte d'interface localise."""
    retour ui.i18n.obtenir_texte(cle, langue)
