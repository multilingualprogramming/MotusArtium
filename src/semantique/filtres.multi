    ],
    Lentille.SYMBOLISME: [
        "Q34379",    # mythologie
        "Q6881637",  # symbole
        "Q45621",    # religion
    ],
    Lentille.EMOTION: [
        "Q9415",     # amour
        "Q26742",    # peur
        "Q40241",    # joie
    ],
    Lentille.MYTHOLOGIE: [
        "Q34379",    # mythologie
        "Q178885",   # déesse
        "Q11042",    # dieu
    ],
    Lentille.RELIGION: [
        "Q45621",    # religion
