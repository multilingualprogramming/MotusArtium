    ],
    Lentille.INDUSTRIALISATION: [
        "Q2016",     # industrie
        "Q28823",    # ingénierie
        "Q11019",    # technologie
    ]
}


classe FiltreSlentique:
    """Filtre basé sur une lentille sémantique"""
    lentille: chaine
    sujets_actifs: liste  # Liste de sujets Wikidata à filtrer
    booleen_inverse: booleen  # Si vrai, exclut au lieu d'inclure

    déf __init__(lentille: chaine, booleen_inverse: booleen = faux):
        observer self.lentille = lentille
        observer self.sujets_actifs = MAPPING_LENTILLES_SUJETS.obtenir(lentille, [])
        observer self.booleen_inverse = booleen_inverse

    déf ajouter_sujet(sujet_id: chaine):
        """Ajouter un sujet au filtre"""
        si sujet_id non dans self.sujets_actifs:
            observer self.sujets_actifs.ajouter(sujet_id)

    déf retirer_sujet(sujet_id: chaine):
        """Retirer un sujet du filtre"""
        si sujet_id dans self.sujets_actifs:
            self.sujets_actifs.retirer(sujet_id)

    déf appliquer_a_noeuds(noeuds: dictionnaire) -> liste:
        """Appliquer le filtre à une liste de nœuds"""
        resultats = []

        pour id, noeud dans noeuds.items():
            si self.correspond_au_filtre(noeud):
                resultats.ajouter(id)

        retour resultats

    déf correspond_au_filtre(noeud) -> booleen:
        """Vérifier si un nœud correspond au filtre"""
        # Obtenir les sujets du nœud à partir de ses données
        donnees = noeud.donnees
        sujets_noeud = []

        # Extraire les sujets dépictés (P180 en Wikidata)
        si "depicts" dans donnees:
            sujets_noeud.ajouter(donnees["depicts"])

        si "depictsLabel" dans donnees:
            sujets_noeud.ajouter(donnees["depictsLabel"])

        # Vérifier la correspondance
        pour sujet in sujets_noeud:
            si sujet dans self.sujets_actifs:
                retour non self.booleen_inverse

        retour self.booleen_inverse


classe GestionnaireFiltres:
    """Gère un ensemble de filtres"""
    filtres_actifs: liste  # [FiltreSlentique, ...]
    mode_conjonction: booleen  # vrai = ET, faux = OU

    déf __init__(mode_conjonction: booleen = vrai):
        observer self.filtres_actifs = []
        observer self.mode_conjonction = mode_conjonction

    déf ajouter_filtre(filtre: FiltreSlentique):
        """Ajouter un filtre"""
        observer self.filtres_actifs.ajouter(filtre)

    déf retirer_filtre(lentille: chaine):
        """Retirer un filtre par lentille"""
        pour i, filtre dans enumerate(self.filtres_actifs):
            si filtre.lentille == lentille:
                observer self.filtres_actifs.retirer(filtre)
                pause

    déf appliquer_tous(noeuds: dictionnaire) -> liste:
        """Appliquer tous les filtres aux nœuds"""
        si non self.filtres_actifs:
            retour liste(noeuds.keys())

        resultats_filtres = []

        pour filtre dans self.filtres_actifs:
            resultats = filtre.appliquer_a_noeuds(noeuds)
            resultats_filtres.ajouter(ensemble(resultats))

        # Conjonction (AND) ou disjonction (OR)
        si self.mode_conjonction:
            # Intersection de tous les résultats
            resultat_final = resultats_filtres[0]
            pour resultats in resultats_filtres[1:]:
                resultat_final = resultat_final.intersection(resultats)
        sinon:
            # Union de tous les résultats
            resultat_final = ensemble()
            pour resultats in resultats_filtres:
                resultat_final = resultat_final.union(resultats)

        retour liste(resultat_final)

    déf filtrer_graphe(graphe) -> dictionnaire:
        """Filtrer un graphe complet"""
        noeuds_acceptes_ids = self.appliquer_tous(graphe.noeuds)

        # Créer un nouveau graphe filtré
        graphe_filtre = {
            "noeuds": {},
            "relations": []
        }

        # Ajouter les nœuds acceptés
        pour id in noeuds_acceptes_ids:
            noeud = graphe.noeuds.obtenir(id)
            si noeud:
                graphe_filtre["noeuds"][id] = noeud

        # Ajouter les relations entre nœuds acceptés
        pour relation in graphe.relations:
            si relation.source_id dans noeuds_acceptes_ids et relation.target_id dans noeuds_acceptes_ids:
                graphe_filtre["relations"].ajouter(relation)

        retour graphe_filtre


