importer ui.etat


enum Lentille:
    """Énumération des lentilles sémantiques"""
    COULEUR = "couleur"
    GEOMETRIE = "geometrie"
    SYMBOLISME = "symbolisme"
    EMOTION = "emotion"
    ABSTRACTION = "abstraction"
    URBANITE = "urbanite"
    MYTHOLOGIE = "mythologie"
    RELIGION = "religion"
    NATURE = "nature"
    POLITIQUE = "politique"
    INDUSTRIALISATION = "industrialisation"


# Mapping des lentilles aux sujets Wikidata
