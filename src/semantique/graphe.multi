classe NoeudGraphe:
    """Représente un nœud dans le graphe de connaissances"""
    id: chaine
    type_noeud: chaine
    etiquette: chaine
    donnees: dictionnaire
    voisins: liste  # IDs des nœuds adjacents

    déf __init__(id: chaine, type_noeud: chaine, etiquette: chaine, donnees: dictionnaire = {}):
        self.id = id
        self.type_noeud = type_noeud
        self.etiquette = etiquette
        self.donnees = donnees
        self.voisins = []


classe RelationGraphe:
    """Représente une relation entre deux nœuds"""
    source_id: chaine
    target_id: chaine
    type_noeud: chaine  # "precede", "suivi_par", "influence", "cree", etc.
    poids: nombre

    déf __init__(source_id: chaine, target_id: chaine, type_noeud: chaine, poids: nombre = 1.0):
        self.source_id = source_id
        self.target_id = target_id
        self.type_noeud = type_noeud
        self.poids = poids


classe Graphe:
    """Graphe de connaissances pour les mouvements, artistes et œuvres d'art"""
    noeuds: dictionnaire  # id -> NoeudGraphe
    relations: liste      # [RelationGraphe]

    déf __init__():
        self.noeuds = {}
        self.relations = []

    déf ajouter_noeud(id: chaine, type_noeud: chaine, etiquette: chaine, donnees: dictionnaire = {}):
        """Ajouter ou mettre à jour un nœud"""
        si id non dans self.noeuds:
            noeud = NoeudGraphe(id, type_noeud, etiquette, donnees)
            self.noeuds[id] = noeud
        sinon:
            self.noeuds[id].donnees = donnees
            self.noeuds[id].etiquette = etiquette

    déf ajouter_relation(source_id: chaine, target_id: chaine, type_noeud: chaine, poids: nombre = 1.0):
        """Ajouter une relation entre deux nœuds"""
        # Vérifier que les nœuds existent
        si source_id non dans self.noeuds ou target_id non dans self.noeuds:
            retour

        # Vérifier si la relation existe déjà
        pour rel dans self.relations:
            si rel.source_id == source_id et rel.target_id == target_id et rel.type_noeud == type_noeud:
                rel.poids = poids
                retour

        # Ajouter la nouvelle relation
        relation = RelationGraphe(source_id, target_id, type_noeud, poids)
        self.relations.ajouter(relation)

        # Ajouter aux voisins
        self.noeuds[source_id].voisins.ajouter(target_id)
        self.noeuds[target_id].voisins.ajouter(source_id)

    déf obtenir_noeud(id: chaine) -> NoeudGraphe:
        """Obtenir un nœud par ID"""
        retour self.noeuds.obtenir(id, nul)

    déf obtenir_voisins(noeud_id: chaine, type_relation: chaine = "") -> liste:
        """Obtenir les nœuds adjacents"""
        voisins = []

        pour relation dans self.relations:
            si relation.source_id == noeud_id:
                si type_relation == "" ou relation.type_noeud == type_relation:
                    voisins.ajouter(relation.target_id)
            sinon si relation.target_id == noeud_id:
                si type_relation == "" ou relation.type_noeud == type_relation:
                    voisins.ajouter(relation.source_id)

        retour voisins

    déf obtenir_relations_noeud(noeud_id: chaine) -> liste:
        """Obtenir toutes les relations d'un nœud"""
        rels = []

        pour relation dans self.relations:
            si relation.source_id == noeud_id ou relation.target_id == noeud_id:
                rels.ajouter(relation)

        retour rels

    déf compter_noeuds() -> nombre:
        """Compter le nombre de nœuds"""
        retour len(self.noeuds.keys())

    déf compter_relations() -> nombre:
        """Compter le nombre de relations"""
        retour len(self.relations)

    déf obtenir_noeuds_par_type(type: chaine) -> liste:
        """Obtenir tous les nœuds d'un type donné"""
        resultats = []

        pour id, noeud dans self.noeuds.items():
            si noeud.type_noeud == type:
                resultats.ajouter(noeud)

        retour resultats

    déf obtenir_relations_par_type(type: chaine) -> liste:
        """Obtenir toutes les relations d'un type donné"""
        resultats = []

        pour relation dans self.relations:
            si relation.type_noeud == type:
                resultats.ajouter(relation)

        retour resultats

    déf chemin_plus_court(noeud_depart_id: chaine, noeud_arrivee_id: chaine) -> liste:
        """Trouver le chemin le plus court entre deux nœuds (BFS)"""
        si noeud_depart_id non dans self.noeuds ou noeud_arrivee_id non dans self.noeuds:
            retour []

        si noeud_depart_id == noeud_arrivee_id:
            retour [noeud_depart_id]

        visites = {noeud_depart_id}
        queue = [[noeud_depart_id]]

        tantque len(queue) > 0:
            chemin = queue.pop(0)
            noeud_actuel = chemin[len(chemin) - 1]

            pour voisin_id dans self.obtenir_voisins(noeud_actuel):
                nouveau_chemin = []
                pour etape_id dans chemin:
                    nouveau_chemin.ajouter(etape_id)
                nouveau_chemin.ajouter(voisin_id)

                si voisin_id == noeud_arrivee_id:
                    retour nouveau_chemin

                si voisin_id non dans visites:
                    visites.ajouter(voisin_id)
                    queue.ajouter(nouveau_chemin)

        retour []

    déf obtenir_voisinage(noeud_id: chaine, profondeur: nombre = 2) -> dictionnaire:
        """Obtenir le voisinage d'un nœud jusqu'à une certaine profondeur"""
        voisinage = {
            "centre": noeud_id,
            "couches": []
        }

        visites = {noeud_id}
        couche_actuelle = [noeud_id]

        pour _ dans intervalle(profondeur):
            prochaine_couche = []
            noeuds_couche = []

            pour noeud_courant_id dans couche_actuelle:
                pour voisin_id dans self.obtenir_voisins(noeud_courant_id):
                    si voisin_id non dans visites:
                        visites.ajouter(voisin_id)
                        prochaine_couche.ajouter(voisin_id)
                        noeud = self.obtenir_noeud(voisin_id)
                        si noeud:
                            noeuds_couche.ajouter({
                                "id": voisin_id,
                                "etiquette": noeud.etiquette,
                                "type": noeud.type_noeud
                            })

            si noeuds_couche:
                voisinage["couches"].ajouter(noeuds_couche)

            couche_actuelle = prochaine_couche
            si non couche_actuelle:
                pause

        retour voisinage

    déf obtenir_composantes_connexes() -> liste:
        """Obtenir les composantes connexes du graphe"""
        visites = {}
        composantes = []

        pour noeud_id dans self.noeuds.keys():
            si noeud_id non dans visites:
                composante = []
                queue = [noeud_id]

                tantque len(queue) > 0:
                    courant = queue.pop(0)

                    si courant non dans visites:
                        visites[courant] = vrai
                        composante.ajouter(courant)

                        pour voisin dans self.obtenir_voisins(courant):
                            si voisin non dans visites:
                                queue.ajouter(voisin)

                si composante:
                    composantes.ajouter(composante)

        retour composantes

    déf exporter_json() -> dictionnaire:
        """Exporter le graphe en JSON"""
        noeuds_json = []
        pour id, noeud dans self.noeuds.items():
            noeuds_json.ajouter({
                "id": noeud.id,
                "type": noeud.type_noeud,
                "etiquette": noeud.etiquette,
                "donnees": noeud.donnees
            })

        relations_json = []
        pour rel dans self.relations:
            relations_json.ajouter({
                "source": rel.source_id,
                "target": rel.target_id,
                "type": rel.type_noeud,
                "poids": rel.poids
            })

        retour {
            "noeuds": noeuds_json,
            "relations": relations_json,
            "stats": {
                "total_noeuds": self.compter_noeuds(),
                "total_relations": self.compter_relations()
            }
        }
