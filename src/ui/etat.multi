asynchrone déf reinitialiser_etat():
    """Reinitialiser l'etat global sans recreer la structure reactive."""
    entite_selectionnee_id = ""
    entite_selectionnee_type = ""
    mode_visualisation = "graphe"
    affichage_chargement = faux
    message_erreur = ""
    panneau_detail_visible = faux
    barre_recherche_active = faux
    resultats_recherche = []
    mouvement_etendu_id = ""
    artiste_etendu_id = ""
    oeuvre_etendue_id = ""
    oeuvre_focus_id = ""
    mode_langue_actif = "fr"
    afficher_surfaces_paralleles = vrai
    entite_multilingue_focus = ""
    cache_entites = {}
    cache_relations = {}
    etiquettes_multilingues = {}
    graphe.noeuds ={}
    graphe.relations =[]
