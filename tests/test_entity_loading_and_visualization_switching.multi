# ============================================================================
# Integration Test: Priority 1 - Core Data Loading & Visualization Switching
# ============================================================================
# Test the complete workflow:
# 1. Load an entity (mouvement/artiste/oeuvre)
# 2. Switch visualization modes
# 3. Apply semantic filters
# 4. Verify state consistency

importer unittest
importer ui.principal
importer ui.etat


test asynchrone déf test_charger_mouvement_workflow():
    """Test: Load a movement and verify state updates"""
    # Load Impressionism
    mouvement = attendre ui.principal.charger_mouvement("Q40415")

    assertion mouvement != {}
    assertion ui.etat.entite_selectionnee_id == "Q40415"
    assertion ui.etat.entite_selectionnee_type == "mouvement"
    assertion ui.etat.mouvement_etendu_id == "Q40415"
    assertion ui.etat.affichage_chargement == faux
    assertion ui.etat.graphe.compter_noeuds() > 0
    assertion ui.etat.graphe.compter_relations() > 0

    afficher("✓ charger_mouvement() workflow successful")


test asynchrone déf test_basculer_visualisation_graphe():
    """Test: Switch to graph visualization (basic case)"""
    attendre ui.principal.charger_mouvement("Q40415")

    etat_avant = ui.etat.mode_visualisation
    resultat = attendre ui.principal.basculer_visualisation("graphe")

    assertion ui.etat.mode_visualisation == "graphe"
    assertion ui.etat.affichage_chargement == faux
    assertion resultat != {}

    afficher("✓ basculer_visualisation('graphe') successful")


test asynchrone déf test_basculer_visualisation_heatmap():
    """Test: Switch to heatmap visualization (requires data loading)"""
    attendre ui.principal.charger_mouvement("Q40415")

    affichage_avant = ui.etat.affichage_chargement
    resultat = attendre ui.principal.basculer_visualisation("heatmap")

    assertion ui.etat.mode_visualisation == "heatmap"
    assertion ui.etat.affichage_chargement == faux
    assertion "Q40415_heatmap" dans ui.etat.cache_relations ou ui.etat.message_erreur == ""

    afficher("✓ basculer_visualisation('heatmap') successful")


test asynchrone déf test_basculer_visualisation_galaxie():
    """Test: Switch to galaxy visualization"""
    attendre ui.principal.charger_mouvement("Q40415")

