test asynchrone déf test_basculer_visualisation_chronologie():
    """Test: Switch to timeline visualization"""
    attendre ui.principal.charger_mouvement("Q40415")

    resultat = attendre ui.principal.basculer_visualisation("chronologie")

    assertion ui.etat.mode_visualisation == "chronologie"
    assertion ui.etat.affichage_chargement == faux

    afficher("✓ basculer_visualisation('chronologie') successful")


test asynchrone déf test_appliquer_filtre_semantique():
    """Test: Apply semantic filter to graph"""
    attendre ui.principal.charger_mouvement("Q40415")

    noeuds_avant = ui.etat.graphe.compter_noeuds()
    relations_avant = ui.etat.graphe.compter_relations()

    resultat = attendre ui.principal.appliquer_filtre("MYTHOLOGIE", vrai)

    assertion resultat != {}
    assertion "graphe_filtre" dans ui.etat.cache_relations
    assertion "MYTHOLOGIE" dans ui.etat.filtres_actifs

    stats = resultat.obtenir("stats", {})
    assertion stats.obtenir("total_noeuds_avant", 0) > 0
    assertion stats.obtenir("total_relations_avant", 0) >= 0

    afficher("✓ appliquer_filtre() successful - Filtered " + \
              chaine(stats.obtenir("total_noeuds_apres", 0)) + \
              " nodes from " + chaine(stats.obtenir("total_noeuds_avant", 0)))


test asynchrone déf test_reinitialiser_filtre():
    """Test: Clear all applied filters"""
    attendre ui.principal.charger_mouvement("Q40415")
    attendre ui.principal.appliquer_filtre("MYTHOLOGIE", vrai)

    assertion "MYTHOLOGIE" dans ui.etat.filtres_actifs
    assertion "graphe_filtre" dans ui.etat.cache_relations

    resultat = attendre ui.principal.reinitialiser_filtre()

    assertion "MYTHOLOGIE" non dans ui.etat.filtres_actifs
    assertion "graphe_filtre" non dans ui.etat.cache_relations ou \
              len(ui.etat.filtres_actifs) == 0

    afficher("✓ reinitialiser_filtre() successful")


test asynchrone déf test_charger_artiste_workflow():
    """Test: Load an artist and verify state updates"""
    attendre ui.principal.charger_mouvement("Q40415")

    # Get first artist from the movement
    pour id_noeud, noeud dans ui.etat.graphe.noeuds.items():
        si noeud.type == "artiste":
            resultat = attendre ui.principal.charger_artiste(id_noeud)

            assertion ui.etat.entite_selectionnee_id == id_noeud
            assertion ui.etat.entite_selectionnee_type == "artiste"
            assertion ui.etat.artiste_etendu_id == id_noeud
            assertion ui.etat.affichage_chargement == faux

            afficher("✓ charger_artiste() workflow successful")
            pause


