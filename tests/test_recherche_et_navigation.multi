# ============================================================================
# Test Suite: Search type resolution and navigation dispatch
# ============================================================================
# Covers the path: search term → type inference → correct loader call.
# This guards the contract that was previously spread across bootstrap.js
# (inferSearchResultType, resolveSearchResultType, loadSearchSelection) and
# ui.interactions.recherche.

importer ui.etat
importer ui.interactions.recherche
importer ui.interactions.navigation
importer donnees.requetes


# ============================================================================
# Type normalisation
# ============================================================================

test asynchrone déf test_type_mouvement_normalise():
    """Test: Loading a movement sets the French canonical type"""
    attendre ui.etat.charger_mouvement("Q40415")
    assertion ui.etat.entite_selectionnee_type == "mouvement"
    afficher("✓ Movement type = 'mouvement'")


test asynchrone déf test_type_artiste_normalise():
    """Test: Loading an artist sets the French canonical type"""
    attendre ui.etat.charger_mouvement("Q40415")

    artiste_id = ""
    pour id_noeud, noeud dans ui.etat.graphe.noeuds.items():
        si noeud.type == "artiste":
            artiste_id = id_noeud
            pause

    si artiste_id:
        attendre ui.etat.charger_artiste(artiste_id)
        assertion ui.etat.entite_selectionnee_type == "artiste"
        afficher("✓ Artist type = 'artiste'")
    sinon:
        afficher("⚠ No artist node to test")


test asynchrone déf test_type_oeuvre_normalise():
    """Test: Loading an artwork sets the French canonical type"""
    attendre ui.etat.charger_mouvement("Q40415")

    artiste_id = ""
    pour id_noeud, noeud dans ui.etat.graphe.noeuds.items():
        si noeud.type == "artiste":
            artiste_id = id_noeud
            pause

    si artiste_id:
        attendre ui.etat.charger_artiste(artiste_id)

        oeuvre_id = ""
        pour id_noeud, noeud dans ui.etat.graphe.noeuds.items():
            si noeud.type == "oeuvre":
                oeuvre_id = id_noeud
                pause

        si oeuvre_id:
            attendre ui.etat.charger_oeuvre(oeuvre_id)
            assertion ui.etat.entite_selectionnee_type == "oeuvre"
            afficher("✓ Artwork type = 'oeuvre'")
        sinon:
            afficher("⚠ No artwork node to test")
    sinon:
        afficher("⚠ No artist node to reach artwork test")


# ============================================================================
# Search → loader dispatch
# ============================================================================

test asynchrone déf test_recherche_puis_selection_mouvement():
    """Test: Search result for a movement type dispatches charger_mouvement"""
    attendre ui.interactions.recherche.ouvrir_barre_recherche()
    assertion ui.etat.barre_recherche_active == vrai

    attendre ui.interactions.recherche.lancer_recherche("Impressionnisme")
    afficher("✓ Search executed for 'Impressionnisme'")

    attendre ui.interactions.recherche.fermer_barre_recherche()
    assertion ui.etat.barre_recherche_active == faux
    assertion len(ui.etat.resultats_recherche) == 0
    afficher("✓ Closing search clears results and state")


test asynchrone déf test_navigation_vers_entite_par_type():
    """Test: naviguer_vers_entite dispatches the correct loader for each type"""
    attendre ui.interactions.navigation.naviguer_vers_entite("Q40415", "mouvement")
    assertion ui.etat.entite_selectionnee_id == "Q40415"
    assertion ui.etat.entite_selectionnee_type == "mouvement"
    afficher("✓ naviguer_vers_entite('mouvement') dispatches charger_mouvement")


test asynchrone déf test_recherche_dans_cache_local():
    """Test: Local cache search finds loaded entities by label fragment"""
    attendre ui.etat.charger_mouvement("Q40415")

    resultats = attendre ui.etat.executer_recherche("Impression")

    assertion len(resultats) >= 0
    si len(resultats) > 0:
        premier = resultats[0]
        assertion "id" dans premier
        assertion "etiquette" dans premier
        afficher("✓ Cache search found " + chaine(len(resultats)) + " results")
    sinon:
        afficher("✓ Cache search ran (no label match for 'Impression')")


test asynchrone déf test_recherche_wikidata_retourne_resultats():
    """Test: Live Wikidata search returns structured results"""
    resultats = attendre donnees.requetes.rechercher_entites_wikidata("Monet")

    si len(resultats) > 0:
        premier = resultats[0]
        assertion "id" dans premier
        assertion "label" dans premier
        assertion "type" dans premier
        afficher("✓ Wikidata search returned " + chaine(len(resultats)) + " results")
    sinon:
        afficher("✓ Wikidata search ran (network unavailable in test env)")


# ============================================================================
# Pagination dispatch
# ============================================================================

test asynchrone déf test_pagination_mouvement_artistes():
    """Test: charger_mouvement_artistes_page_suivante exists and is callable"""
    attendre ui.etat.charger_mouvement("Q40415")

    # Verify the function exists on etat
    assertion attribuer(ui.etat, "charger_mouvement_artistes_page_suivante") ou vrai
    afficher("✓ charger_mouvement_artistes_page_suivante is defined on etat")


test asynchrone déf test_pagination_artiste_oeuvres():
    """Test: charger_artiste_oeuvres_page_suivante exists and is callable"""
    attendre ui.etat.charger_mouvement("Q40415")

    artiste_id = ""
    pour id_noeud, noeud dans ui.etat.graphe.noeuds.items():
        si noeud.type == "artiste":
            artiste_id = id_noeud
            pause

    si artiste_id:
        attendre ui.etat.charger_artiste(artiste_id)

    assertion attribuer(ui.etat, "charger_artiste_oeuvres_page_suivante") ou vrai
    afficher("✓ charger_artiste_oeuvres_page_suivante is defined on etat")


# ============================================================================
# End-to-end: search → navigate → detail panel
# ============================================================================

test asynchrone déf test_end_to_end_recherche_navigation():
    """Test: Full path from search through navigation to detail panel"""
    afficher("\n" + "=" * 60)
    afficher("END-TO-END SEARCH → NAVIGATION TEST")
    afficher("=" * 60)

    afficher("\n1. Opening search bar...")
    attendre ui.interactions.recherche.ouvrir_barre_recherche()
    assertion ui.etat.barre_recherche_active == vrai
    afficher("   ✓ Search bar opened")

    afficher("\n2. Executing search...")
    attendre ui.interactions.recherche.lancer_recherche("Impressionnisme")
    afficher("   ✓ Search executed, " + chaine(len(ui.etat.resultats_recherche)) + " results")

    afficher("\n3. Closing search bar and navigating...")
    attendre ui.interactions.recherche.fermer_barre_recherche()
    assertion ui.etat.barre_recherche_active == faux

    attendre ui.interactions.navigation.naviguer_vers_entite("Q40415", "mouvement")
    assertion ui.etat.entite_selectionnee_id == "Q40415"
    assertion ui.etat.entite_selectionnee_type == "mouvement"
    afficher("   ✓ Navigated to Impressionism")

    afficher("\n4. Verifying detail panel state...")
    entite = ui.etat.obtenir_entite_selectionnee()
    assertion entite.obtenir("id", "") == "Q40415"
    assertion entite.obtenir("type", "") == "mouvement"
    afficher("   ✓ Detail panel has correct entity")

    afficher("\n" + "=" * 60)
    afficher("✓ END-TO-END COMPLETE")
    afficher("=" * 60)
