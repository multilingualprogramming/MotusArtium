test asynchrone déf test_panneau_detail_affiche_oeuvre():
    """Test: Detail panel shows correct artwork info"""
    attendre ui.principal.charger_mouvement("Q40415")

    artiste_id = ""
    pour id_noeud, noeud dans ui.etat.graphe.noeuds.items():
        si noeud.type == "artiste":
            artiste_id = id_noeud
            pause

    si artiste_id:
        attendre ui.principal.charger_artiste(artiste_id)

        oeuvre_id = ""
        pour id_noeud, noeud dans ui.etat.graphe.noeuds.items():
            si noeud.type == "oeuvre":
                oeuvre_id = id_noeud
                pause

        si oeuvre_id:
            attendre ui.principal.charger_oeuvre(oeuvre_id)

            entite = ui.etat.obtenir_entite_selectionnee()

            assertion entite.obtenir("type", "") == "oeuvre"

            donnees = entite.obtenir("donnees", {})
            assertion donnees.obtenir("artworkLabel", {}).obtenir("value", "") != ""

            afficher("✓ Detail panel displays artwork data correctly")
        sinon:
            afficher("⚠ No artwork found to test detail panel")
    sinon:
        afficher("⚠ No artist found to test artwork detail panel")


test asynchrone déf test_end_to_end_search_and_detail():
    """Test: Complete user workflow with search and detail panel"""
    afficher("\n" + "=" * 60)
    afficher("END-TO-END SEARCH & DETAIL PANEL TEST")
    afficher("=" * 60)

    # Step 1: Load a movement
    afficher("\n1. Loading Impressionism movement...")
    attendre ui.principal.charger_mouvement("Q40415")
    assertion ui.etat.entite_selectionnee_id == "Q40415"
    afficher("   ✓ Movement loaded")

    # Step 2: Open search bar
    afficher("\n2. Opening search bar...")
    attendre ui.interactions.recherche.ouvrir_barre_recherche()
    assertion ui.etat.barre_recherche_active == vrai
    afficher("   ✓ Search bar opened")

    # Step 3: Execute search
    afficher("\n3. Executing search for 'impressionist'...")
    attendre ui.interactions.recherche.lancer_recherche("impressionist")
    afficher("   ✓ Search executed, " + chaine(len(ui.etat.resultats_recherche)) + " results")

    # Step 4: Close search bar
    afficher("\n4. Closing search bar...")
    attendre ui.interactions.recherche.fermer_barre_recherche()
    assertion ui.etat.barre_recherche_active == faux
    assertion len(ui.etat.resultats_recherche) == 0
    afficher("   ✓ Search bar closed, results cleared")

    # Step 5: Check detail panel
    afficher("\n5. Checking detail panel state...")
    entite = ui.etat.obtenir_entite_selectionnee()
    assertion entite.obtenir("type", "") == "mouvement"
    afficher("   ✓ Detail panel shows movement details")

    # Step 6: Navigate to an artist
    afficher("\n6. Navigating to associated artist...")
    artiste_id = ""
    pour id_noeud, noeud dans ui.etat.graphe.noeuds.items():
        si noeud.type == "artiste":
            artiste_id = id_noeud
            pause

    si artiste_id:
        attendre ui.principal.charger_artiste(artiste_id)
        entite = ui.etat.obtenir_entite_selectionnee()
        assertion entite.obtenir("type", "") == "artiste"
        afficher("   ✓ Navigated to artist, detail panel updated")
    sinon:
        afficher("   ⚠ No artist found to navigate to")

    afficher("\n" + "=" * 60)
    afficher("✓ END-TO-END TEST COMPLETE")
    afficher("=" * 60)
